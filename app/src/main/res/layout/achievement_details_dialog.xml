<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <View
        android:id="@+id/corners_cut_shape"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/dialog_border"
        android:contentDescription="@string/card_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/gradient_left"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@drawable/blue_linear_gradiant"
        android:rotation="180"
        android:translationX="5dp"
        app:layout_constraintDimensionRatio="56:1"
        app:layout_constraintEnd_toStartOf="@id/title_shape"
        app:layout_constraintTop_toTopOf="@id/corners_cut_shape" />

    <View
        android:id="@+id/gradient_right"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@drawable/blue_linear_gradiant"
        android:translationX="-5dp"
        app:layout_constraintDimensionRatio="56:1"
        app:layout_constraintStart_toEndOf="@id/title_shape"
        app:layout_constraintTop_toTopOf="@id/corners_cut_shape" />

    <ImageView
        android:id="@+id/title_shape"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:contentDescription="@string/title"
        android:src="@drawable/heptagon_shape"
        app:layout_constraintDimensionRatio="145:40"
        app:layout_constraintEnd_toEndOf="@id/corners_cut_shape"
        app:layout_constraintStart_toStartOf="@id/corners_cut_shape"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/title_txt"
        style="@style/Title.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/achievements"
        android:textColor="@color/on_primary"
        app:layout_constraintBottom_toBottomOf="@+id/title_shape"
        app:layout_constraintEnd_toEndOf="@id/title_shape"
        app:layout_constraintStart_toStartOf="@id/title_shape"
        app:layout_constraintTop_toTopOf="@id/title_shape" />

    <ImageView
        android:id="@+id/close_shape"
        android:layout_width="0dp"
        android:layout_height="26dp"
        android:clickable="true"
        android:contentDescription="@string/close_shape"
        android:src="@drawable/close"
        app:layout_constraintDimensionRatio="22:26"
        app:layout_constraintEnd_toEndOf="@+id/corners_cut_shape"
        app:layout_constraintTop_toTopOf="@+id/corners_cut_shape" />

    <View
        android:id="@+id/item_shape_view"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/character_card_details"
        app:layout_constraintEnd_toEndOf="@+id/corners_cut_shape"
        app:layout_constraintStart_toStartOf="@+id/corners_cut_shape"
        app:layout_constraintTop_toBottomOf="@+id/title_shape" />

    <TextView
        android:id="@+id/validation_txt"
        style="@style/Title.Medium"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/explorer"
        android:textColor="@color/shade_primary"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="@+id/item_shape_view"
        app:layout_constraintStart_toStartOf="@+id/item_shape_view"
        app:layout_constraintTop_toTopOf="@+id/item_shape_view" />

    <ImageView
        android:id="@+id/celebrate_image"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="-30dp"
        android:layout_marginEnd="-6dp"
        android:contentDescription="@string/character_image"
        android:src="@drawable/celebrate_img"
        app:layout_constraintBottom_toBottomOf="@+id/item_shape_view"
        app:layout_constraintEnd_toEndOf="@+id/item_shape_view"
        app:layout_constraintTop_toTopOf="@+id/item_shape_view" />

    <ImageView
        android:id="@+id/achievement_image"
        android:layout_width="65dp"
        android:layout_height="64dp"
        android:layout_marginTop="-20dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/character_image"
        android:src="@drawable/achievement_1"
        app:layout_constraintBottom_toBottomOf="@+id/item_shape_view"
        app:layout_constraintEnd_toEndOf="@+id/item_shape_view"
        app:layout_constraintTop_toTopOf="@+id/item_shape_view" />

    <TextView
        android:id="@+id/achievement_description"
        style="@style/Body.Small"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="62dp"
        android:text="@string/you_love_experimenting_and_discovering_you_ve_tried_several_categories_and_aren_t_limited_to_just_none_how_to_get_play_in_at_least_4_different_categories"
        android:textColor="@color/shade_secondary"
        app:layout_constraintEnd_toEndOf="@+id/corners_cut_shape"
        app:layout_constraintStart_toStartOf="@+id/corners_cut_shape"
        app:layout_constraintTop_toBottomOf="@+id/item_shape_view" />

    <LinearLayout
        android:id="@+id/btn_share"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/primary_button_background"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/btn_ok"
        app:layout_constraintEnd_toStartOf="@+id/btn_ok"
        app:layout_constraintStart_toStartOf="@+id/guideline"
        app:layout_constraintTop_toTopOf="@+id/btn_ok"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.5">

        <TextView
            android:id="@+id/txt_share"
            style="@style/Label.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share_with_friends"
            android:textAllCaps="false"
            android:textColor="@drawable/primary_button_text_color"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/ic_share"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/on_primary"
            android:contentDescription="@string/share_with_friends"
            android:src="@drawable/ic_share" />

    </LinearLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="12dp"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="12dp"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_ok"
        style="@style/Label.Medium"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginTop="62dp"
        android:layout_marginBottom="36dp"
        android:background="@drawable/secondary_button_background"
        android:text="@string/ok"
        android:textColor="@drawable/secondary_button_text_color"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@+id/corners_cut_shape"
        app:layout_constraintEnd_toEndOf="@id/guideline2"
        app:layout_constraintStart_toEndOf="@+id/btn_share"
        app:layout_constraintTop_toBottomOf="@+id/achievement_description" />

</androidx.constraintlayout.widget.ConstraintLayout>