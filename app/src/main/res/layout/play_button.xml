<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="36dp">

        <View
            android:id="@+id/gradient_line"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:background="@drawable/blue_gradient" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/appCompatButton"
                style="@style/Label.Medium"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/play_button_background"
                android:gravity="center"
                android:text="@string/play_now"
                android:textColor="@color/on_primary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.6" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.5" />

            <ImageView
                android:id="@+id/star_right"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginStart="37dp"
                android:layout_marginTop="7dp"
                android:contentDescription="@string/start_right_icon"
                android:elevation="4dp"
                android:src="@drawable/ic_star"
                app:layout_constraintStart_toStartOf="@id/guideline_start"
                app:layout_constraintTop_toTopOf="@id/appCompatButton" />

            <ImageView
                android:id="@+id/star_left"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="13dp"
                android:layout_marginEnd="40dp"
                android:contentDescription="@string/start_left_icon"
                android:elevation="4dp"
                android:src="@drawable/ic_star"
                app:layout_constraintEnd_toEndOf="@id/guideline_start"
                app:layout_constraintTop_toTopOf="@id/appCompatButton" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </RelativeLayout>
</layout>