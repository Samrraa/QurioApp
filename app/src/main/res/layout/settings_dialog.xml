<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/corners_cut_shape"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/dialog_border"
        android:paddingBottom="36dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/close_shape"
            android:layout_width="0dp"
            android:layout_height="26dp"
            android:clickable="true"
            android:contentDescription="@string/card_background"
            android:src="@drawable/close"
            app:layout_constraintDimensionRatio="22:26"
            app:layout_constraintEnd_toEndOf="@+id/corners_cut_shape"
            app:layout_constraintTop_toTopOf="@+id/corners_cut_shape" />

        <LinearLayout
            android:id="@+id/layout_sound"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/icon_sound"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/sound_setting"
                android:src="@drawable/ic_sound"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tv_sound"
                style="@style/Body.Small"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="0.3"
                android:text="@string/sound_setting"
                android:textColor="@color/shade_primary"
                android:textSize="16sp" />

            <SeekBar
                android:id="@+id/seekbar_sound"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="0.7"
                android:max="110"
                android:progress="70"
                android:progressDrawable="@drawable/seekbar_background"
                android:splitTrack="false"
                android:thumb="@drawable/ic_polygon"
                android:thumbTint="@null" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_music"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_sound">

            <ImageView
                android:id="@+id/icon_music"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/music"
                android:src="@drawable/ic_music"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tv_music"
                style="@style/Body.Small"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="0.3"
                android:text="@string/music"
                android:textColor="@color/shade_primary"
                android:textSize="16sp" />

            <SeekBar
                android:id="@+id/seekbar_music"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="0.7"
                android:max="110"
                android:progress="30"
                android:progressDrawable="@drawable/seekbar_background"
                android:splitTrack="false"
                android:thumb="@drawable/ic_polygon"
                android:thumbTint="@null" />
        </LinearLayout>

        <!-- Divider Line -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/background_divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_music" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/primary_button_background"
            android:text="@string/save_changes"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            app:layout_constraintEnd_toStartOf="@id/btn_discard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_discard"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="2dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/secondary_button_background"
            android:text="@string/discard"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btn_save"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tv_title"
        style="@style/Title.Small"
        android:layout_width="145dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:background="@drawable/heptagon_shape"
        android:elevation="8dp"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="12dp"
        android:text="@string/settings_dialog"
        android:textAlignment="center"
        android:textColor="@color/on_primary"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@drawable/blue_linear_gradiant"
        android:rotation="180"
        android:translationX="10dp"
        app:layout_constraintDimensionRatio="56:1"
        app:layout_constraintEnd_toStartOf="@id/tv_title"
        app:layout_constraintTop_toTopOf="@id/corners_cut_shape" />

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@drawable/blue_linear_gradiant"
        android:translationX="-10dp"
        app:layout_constraintDimensionRatio="56:1"
        app:layout_constraintStart_toEndOf="@id/tv_title"
        app:layout_constraintTop_toTopOf="@id/corners_cut_shape" />

</androidx.constraintlayout.widget.ConstraintLayout>