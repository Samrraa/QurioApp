<resources>

    <style name="Base.Theme.QurioApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/fredoka_one</item>
    </style>

    <style name="Theme.QurioApp" parent="Base.Theme.QurioApp" />

    <style name="Theme.QurioApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/surface</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <item name="windowSplashScreenAnimationDuration">2000</item>
        <item name="postSplashScreenTheme">@style/Theme.QurioApp</item>
    </style>

    <style name="Headline">
        <item name="android:fontFamily">@font/fredoka_one</item>
        <item name="android:fontWeight">600</item>
    </style>

    <style name="Headline.Large" parent="Headline">
        <item name="android:textSize">28sp</item>
        <item name="android:lineHeight">42sp</item>
    </style>

    <style name="Headline.Medium" parent="Headline">
        <item name="android:textSize">24sp</item>
        <item name="android:lineHeight">36dp</item>
    </style>

    <style name="Headline.Small" parent="Headline">
        <item name="android:textSize">20sp</item>
        <item name="android:lineHeight">30dp</item>
    </style>

    <style name="Title">
        <item name="android:fontFamily">@font/fredoka_one</item>
        <item name="android:fontWeight">600</item>
    </style>

    <style name="Title.Large" parent="Title">
        <item name="android:textSize">20sp</item>
        <item name="android:lineHeight">30dp</item>
    </style>

    <style name="Title.Medium" parent="Title">
        <item name="android:textSize">18sp</item>
        <item name="android:lineHeight">28dp</item>
    </style>

    <style name="Title.Small" parent="Title">
        <item name="android:textSize">16sp</item>
        <item name="android:fontWeight">500</item>
        <item name="android:lineHeight">24dp</item>
    </style>

    <style name="Body">
        <item name="android:fontFamily">@font/fredoka_regular</item>
        <item name="android:fontWeight">400</item>
    </style>

    <style name="Body.Large" parent="Body">
        <item name="android:textSize">18sp</item>
        <item name="android:lineHeight">28dp</item>
    </style>

    <style name="Body.Medium" parent="Body">
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">24dp</item>
    </style>

    <style name="Body.Small" parent="Body">
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">22dp</item>
    </style>

    <style name="Label">
        <item name="android:fontFamily">@font/fredoka_one</item>
        <item name="android:fontWeight">500</item>
    </style>

    <style name="Label.Large" parent="Label">
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">24dp</item>
    </style>

    <style name="Label.Medium" parent="Label">
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">22dp</item>
    </style>

    <style name="Label.Small" parent="Label">
        <item name="android:textSize">10sp</item>
        <item name="android:lineHeight">16dp</item>
    </style>

    <style name="Label.XSmall" parent="Label">
        <item name="android:fontFamily">@font/fredoka_regular</item>
        <item name="android:textSize">10sp</item>
        <item name="android:lineHeight">14dp</item>
    </style>


    <!-- Button Styles   -->
    <style name="Button" parent="Label.Medium">
        <item name="android:gravity">center</item>
        <item name="android:textColor">@drawable/secondary_button_text_color</item>
    </style>

    <style name="Button.Primary" parent="Button">
        <item name="android:background">@drawable/primary_button_background</item>
        <item name="android:textColor">@drawable/primary_button_text_color</item>
    </style>

    <style name="Button.Secondary" parent="Button">
        <item name="android:background">@drawable/secondary_button_background</item>
    </style>

    <style name="Button.Text" parent="Button">
        <item name="android:background">#00000000</item>
    </style>

</resources>